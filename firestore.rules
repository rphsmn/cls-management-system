rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // USER PROFILES - All authenticated users can read and create, HR can update any user
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // LEAVE REQUESTS - All authenticated can read, create, update
    match /leaveRequests/{requestId} {
      allow read, create, update: if isAuthenticated();
    }
    
    // COMPANY EVENTS - All authenticated users can read and write
    match /company_events/{eventId} {
      allow read, write: if isAuthenticated();
    }
    
    // AUDIT LOGS - All authenticated users can read and create
    match /auditLogs/{logId} {
      allow read, create: if isAuthenticated();
    }
    
    // NOTIFICATIONS - Users can read; updates/deletes allowed for any authenticated (filtered by role in app)
    match /notifications/{notifId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
  }
}
